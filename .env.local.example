# ─── Database ────────────────────────────────────────────────────────────────
# Local SQLite (dev)
DATABASE_URL="file:./dev.db"

# Turso (production) — set both for remote libSQL
# DATABASE_URL="libsql://your-db.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# ─── Authentication secrets ───────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET_VENDOR="replace-with-32-char-random-secret"
JWT_SECRET_AFFILIATE="replace-with-another-32-char-secret"

# ─── Paystack ─────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="your-email@gmail.com"

# ─── Cron authentication ──────────────────────────────────────────────────────
CRON_SECRET="replace-with-random-secret-for-cron-auth"

# ─── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3001"
# Production: APP_URL="https://store.teaketer.com"
